                    <small class="field-error"><?= htmlspecialchars((string) $errors['author'], ENT_QUOTES, 'UTF-8') ?></small>
                <?php endif; ?>
            </label>

            <label class="field">
                <span>The loai</span>
                <input list="category-options" name="category" value="<?= htmlspecialchars((string) ($form['category'] ?? ''), ENT_QUOTES, 'UTF-8') ?>" placeholder="Tieu thuyet, Khoa hoc...">
                <datalist id="category-options">
                    <?php foreach ($categories as $category): ?>
                        <option value="<?= htmlspecialchars($category, ENT_QUOTES, 'UTF-8') ?>">
                    <?php endforeach; ?>
                </datalist>
                <?php if (!empty($errors['category'])): ?>
                    <small class="field-error"><?= htmlspecialchars((string) $errors['category'], ENT_QUOTES, 'UTF-8') ?></small>
                <?php endif; ?>
            </label>

            <label class="field">
                <span>Nha xuat ban</span>
                <input type="text" name="publisher" value="<?= htmlspecialchars((string) ($form['publisher'] ?? ''), ENT_QUOTES, 'UTF-8') ?>" placeholder="NXB Tre">
            </label>

            <label class="field">
                <span>Nam xuat ban</span>
                <input type="number" name="published_year" value="<?= htmlspecialchars((string) ($form['published_year'] ?? ''), ENT_QUOTES, 'UTF-8') ?>" placeholder="2024">
                <?php if (!empty($errors['published_year'])): ?>
                    <small class="field-error"><?= htmlspecialchars((string) $errors['published_year'], ENT_QUOTES, 'UTF-8') ?></small>
                <?php endif; ?>
            </label>

            <label class="field">
                <span>Ngon ngu</span>
                <input type="text" name="language" value="<?= htmlspecialchars((string) ($form['language'] ?? 'Tiếng Việt'), ENT_QUOTES, 'UTF-8') ?>" placeholder="Tieng Viet">
            </label>

            <label class="field">
                <span>ISBN</span>
                <input type="text" name="isbn" value="<?= htmlspecialchars((string) ($form['isbn'] ?? ''), ENT_QUOTES, 'UTF-8') ?>" placeholder="978-604-xx">
                <?php if (!empty($errors['isbn'])): ?>
                    <small class="field-error"><?= htmlspecialchars((string) $errors['isbn'], ENT_QUOTES, 'UTF-8') ?></small>
                <?php endif; ?>
            </label>

            <label class="field">
                <span>So luong tong</span>
                <input type="number" name="quantity" value="<?= htmlspecialchars((string) ($form['quantity'] ?? '1'), ENT_QUOTES, 'UTF-8') ?>" min="0">
                <?php if (!empty($errors['quantity'])): ?>
                    <small class="field-error"><?= htmlspecialchars((string) $errors['quantity'], ENT_QUOTES, 'UTF-8') ?></small>
                <?php endif; ?>
            </label>
        </div>

        <label class="field">
            <span>Lien ket anh bia</span>
            <input type="url" name="cover_image" value="<?= htmlspecialchars((string) ($form['cover_image'] ?? ''), ENT_QUOTES, 'UTF-8') ?>" placeholder="https://...">
            <?php if (!empty($errors['cover_image'])): ?>
                <small class="field-error"><?= htmlspecialchars((string) $errors['cover_image'], ENT_QUOTES, 'UTF-8') ?></small>
