                <strong>Thong tin ton kho hien tai</strong>
                <p>Dang duoc muon: <?= (int) ($form['borrowed_quantity'] ?? 0) ?> ban.</p>
                <p>Con kha dung: <?= (int) ($form['available_quantity'] ?? 0) ?> ban.</p>
            </div>
        <?php endif; ?>

        <div class="form-actions">
            <button type="submit" class="button button-primary"><?= $isEdit ? 'Luu thay doi' : 'Them sach' ?></button>
            <a class="button button-secondary" href="<?= $backUrl ?>">Huy</a>
        </div>
    </form>
</section>
