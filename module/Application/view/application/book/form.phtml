<?php
declare(strict_types=1);

$mode = $mode ?? 'create';
$form = $form ?? [];
$errors = $errors ?? [];
$categories = $categories ?? [];
$isEdit = $mode === 'edit';
$backUrl = $this->url('book');
$actionUrl = $isEdit
    ? $this->url('book', ['action' => 'edit', 'id' => (int) ($form['id'] ?? 0)])
    : $this->url('book', ['action' => 'create']);
?>
<section class="panel form-panel">
    <div class="section-head">
        <div>
            <p class="eyebrow"><?= $isEdit ? 'Cap nhat dau sach' : 'Them dau sach' ?></p>
            <h1><?= $isEdit ? 'Chinh sua thong tin sach' : 'Them sach moi vao kho' ?></h1>
        </div>
        <a class="text-link" href="<?= $backUrl ?>">Quay lai danh sach sach</a>
    </div>

    <form method="post" action="<?= $actionUrl ?>" class="form-grid">
        <div class="form-columns">
            <label class="field">
                <span>Ten sach</span>
                <input type="text" name="title" value="<?= htmlspecialchars((string) ($form['title'] ?? ''), ENT_QUOTES, 'UTF-8') ?>" placeholder="Vi du: Sapiens">
                <?php if (!empty($errors['title'])): ?>
                    <small class="field-error"><?= htmlspecialchars((string) $errors['title'], ENT_QUOTES, 'UTF-8') ?></small>
                <?php endif; ?>
            </label>

            <label class="field">
                <span>Tac gia</span>
                <input type="text" name="author" value="<?= htmlspecialchars((string) ($form['author'] ?? ''), ENT_QUOTES, 'UTF-8') ?>" placeholder="Yuval Noah Harari">
