<?php
declare(strict_types=1);

$books = $books ?? [];
$categories = $categories ?? [];
$filters = $filters ?? [];

$statusLabels = [
    'available' => 'San sang',
    'low_stock' => 'Sap het',
    'out_of_stock' => 'Het sach',
];
?>
<section class="hero-surface">
    <div>
        <p class="eyebrow">Kho sach</p>
        <h1>Quan ly dau sach thu vien</h1>
        <p class="section-copy">
            Theo doi ton kho, tinh trang kha dung va cap nhat thong tin chi tiet cho tung cuon sach.
        </p>
    </div>
    <div class="hero-actions">
        <a class="button button-primary" href="<?= $this->url('book', ['action' => 'create']) ?>">Them sach moi</a>
    </div>
</section>

<section class="panel">
    <form method="get" action="<?= $this->url('book') ?>" class="filter-grid">

        <label class="field">
            <span>Tim kiem</span>
            <input
                type="text"
                name="search"
                value="<?= htmlspecialchars((string) ($filters['search'] ?? ''), ENT_QUOTES, 'UTF-8') ?>"
                placeholder="Ten sach, tac gia hoac ISBN"
            >
        </label>

        <label class="field">
            <span>The loai</span>
            <select name="category">
                <option value="">Tat ca the loai</option>
                <?php foreach ($categories as $category): ?>
                    <option value="<?= htmlspecialchars($category, ENT_QUOTES, 'UTF-8') ?>"<?= ($filters['category'] ?? '') === $category ? ' selected' : '' ?>>
                        <?= htmlspecialchars($category, ENT_QUOTES, 'UTF-8') ?>
                    </option>
                <?php endforeach; ?>
            </select>
        </label>

        <label class="field">
            <span>Trang thai</span>
            <select name="status">
                <option value="">Tat ca trang thai</option>
                <?php foreach ($statusLabels as $status => $label): ?>
                    <option value="<?= htmlspecialchars($status, ENT_QUOTES, 'UTF-8') ?>"<?= ($filters['status'] ?? '') === $status ? ' selected' : '' ?>>
                        <?= htmlspecialchars($label, ENT_QUOTES, 'UTF-8') ?>
                    </option>
                <?php endforeach; ?>
            </select>
        </label>

        <div class="filter-actions">
            <button type="submit" class="button button-primary">Loc du lieu</button>
            <a class="button button-secondary" href="<?= $this->url('book') ?>">Dat lai</a>
        </div>
    </form>
</section>

<section class="panel">
    <div class="section-head">
        <div>
            <p class="eyebrow">Danh muc sach</p>
            <h2>Danh sach sach hien co</h2>
        </div>
    </div>

    <div class="table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Ten sach</th>
                    <th>Tac gia</th>
                    <th>The loai</th>
                    <th>Tong</th>
                    <th>Con lai</th>
                    <th>Trang thai</th>
                    <th>Thao tac</th>
                </tr>
            </thead>
            <tbody>
                <?php if ($books === []): ?>
                    <tr>
                        <td colspan="8" class="table-empty">Chua co dau sach nao phu hop bo loc hien tai.</td>
                    </tr>
                <?php else: ?>
                    <?php foreach ($books as $book): ?>
                        <?php
                        $confirmMessage = 'Ban co chac chan muon xoa sach ' . $book['title'] . ' khong?';
                        $status = (string) $book['status'];
                        ?>
                        <tr>
                            <td>#<?= (int) $book['id'] ?></td>
                            <td>
                                <div class="cell-title"><?= htmlspecialchars((string) $book['title'], ENT_QUOTES, 'UTF-8') ?></div>
                                <?php if (!empty($book['isbn'])): ?>
                                    <small class="cell-subtitle">ISBN: <?= htmlspecialchars((string) $book['isbn'], ENT_QUOTES, 'UTF-8') ?></small>
                                <?php endif; ?>
                            </td>
                            <td><?= htmlspecialchars((string) $book['author'], ENT_QUOTES, 'UTF-8') ?></td>
                            <td><?= htmlspecialchars((string) $book['category'], ENT_QUOTES, 'UTF-8') ?></td>
                            <td><?= (int) $book['quantity'] ?></td>
                            <td><?= (int) $book['available_quantity'] ?></td>
                            <td><span class="status-pill status-pill-<?= htmlspecialchars($status, ENT_QUOTES, 'UTF-8') ?>"><?= htmlspecialchars($statusLabels[$status] ?? $status, ENT_QUOTES, 'UTF-8') ?></span></td>
                            <td class="actions">
                                <a class="button button-secondary button-small" href="<?= $this->url('book', ['action' => 'edit', 'id' => $book['id']]) ?>">Sua</a>
                                <form
                                    method="post"
                                    action="<?= $this->url('book', ['action' => 'delete', 'id' => $book['id']]) ?>"
                                    class="inline-form"
                                    data-confirm="<?= htmlspecialchars($confirmMessage, ENT_QUOTES, 'UTF-8') ?>"
                                >
                                    <button type="submit" class="button button-danger button-small">Xoa</button>
                                </form>
                            </td>
                        </tr>
                    <?php endforeach; ?>
                <?php endif; ?>
            </tbody>
        </table>
    </div>
</section>
