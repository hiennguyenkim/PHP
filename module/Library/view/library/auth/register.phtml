<?php $this->headTitle('Đăng ký');
$this->layout('layout/library-layout'); ?>
<div class="card login-card p-4 w-100" style="max-width:480px">
    <div class="text-center mb-4">
        <div class="fs-1 text-primary"><i class="bi bi-person-plus"></i></div>
        <h1 class="h4 fw-bold">Tạo tài khoản mới</h1>
        <p class="text-muted small">Đăng ký để truy cập trang quản lý (Index).</p>
    </div>
    <form method="POST" action="<?= $this->url('library/auth', ['action' => 'register']) ?>">
        <div class="mb-3">
            <label class="form-label fw-semibold">Tên đăng nhập</label>
            <input type="text" name="username" class="form-control" placeholder="username"
                   value="<?= htmlspecialchars((string) $form->get('username')->getValue()) ?>" required>
            <?php $messages = $form->get('username')->getMessages(); if ($messages) : ?>
                <div class="text-danger small mt-1"><?= htmlspecialchars(implode(', ', $messages)) ?></div>
            <?php endif; ?>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Email</label>
            <input type="email" name="email" class="form-control" placeholder="name@example.com"
                   value="<?= htmlspecialchars((string) $form->get('email')->getValue()) ?>" required>
            <?php $messages = $form->get('email')->getMessages(); if ($messages) : ?>
                <div class="text-danger small mt-1"><?= htmlspecialchars(implode(', ', $messages)) ?></div>
            <?php endif; ?>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Mật khẩu</label>
            <input type="password" name="password" class="form-control" placeholder="Tối thiểu 8 ký tự" required>
            <?php $messages = $form->get('password')->getMessages(); if ($messages) : ?>
                <div class="text-danger small mt-1"><?= htmlspecialchars(implode(', ', $messages)) ?></div>
            <?php endif; ?>
        </div>
        <div class="mb-4">
            <label class="form-label fw-semibold">Xác nhận mật khẩu</label>
            <input type="password" name="password_confirm" class="form-control" placeholder="Nhập lại mật khẩu" required>
            <?php $messages = $form->get('password_confirm')->getMessages(); if ($messages) : ?>
                <div class="text-danger small mt-1"><?= htmlspecialchars(implode(', ', $messages)) ?></div>
            <?php endif; ?>
        </div>
        <?= $this->formHidden($form->get('csrf')) ?>
        <?php $messages = $form->get('csrf')->getMessages(); if ($messages) : ?>
            <div class="text-danger small mb-3"><?= htmlspecialchars(implode(', ', $messages)) ?></div>
        <?php endif; ?>
        <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
            <i class="bi bi-check-circle me-1"></i>Đăng ký
        </button>
    </form>
    <p class="text-center text-muted small mt-3 mb-0">
        Đã có tài khoản?
        <a href="<?= $this->url('library/auth', ['action' => 'login']) ?>" class="text-decoration-none">Đăng nhập ngay</a>
    </p>
</div>
