<?php $this->headTitle('Lập phiếu mượn'); $this->layout('layout/library-layout'); ?>
<?php
$bookOptions = $form->get('book_id')->getValueOptions();
$userOptions = $form->get('user_id')->getValueOptions();
?>
<div class="row justify-content-center">
<div class="col-lg-6">
    <div class="d-flex align-items-center mb-4">
        <a href="<?= $this->url('library/transaction') ?>" class="btn btn-outline-secondary btn-sm me-3">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="h4 fw-bold mb-0">Lập phiếu mượn sách</h1>
    </div>

    <div class="card">
        <div class="card-body p-4">
            <form method="POST" action="<?= $this->url('library/transaction', ['action' => 'borrow']) ?>">
                <?php if ($bookOptions === []): ?>
                    <div class="alert alert-warning">
                        Hiện chưa có sách khả dụng để lập phiếu mượn.
                    </div>
                <?php endif; ?>
                <?php if ($userOptions === []): ?>
                    <div class="alert alert-warning">
                        Hiện chưa có tài khoản sinh viên nào trong hệ thống.
                    </div>
                <?php endif; ?>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Sách *</label>
                    <?= $this->formSelect($form->get('book_id')->setAttribute('class', 'form-select')) ?>
                    <?php $msgs = $form->get('book_id')->getMessages(); if ($msgs): ?>
                        <div class="text-danger small mt-1"><?= htmlspecialchars(implode(', ', $msgs)) ?></div>
                    <?php endif; ?>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Sinh viên *</label>
                    <?= $this->formSelect($form->get('user_id')->setAttribute('class', 'form-select')) ?>
                    <?php $msgs = $form->get('user_id')->getMessages(); if ($msgs): ?>
                        <div class="text-danger small mt-1"><?= htmlspecialchars(implode(', ', $msgs)) ?></div>
                    <?php endif; ?>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col">
                        <label class="form-label fw-semibold">Ngày mượn *</label>
                        <input type="date" name="borrow_date" class="form-control"
                               value="<?= htmlspecialchars((string)$form->get('borrow_date')->getValue()) ?>" required>
                    </div>
                    <div class="col">
                        <label class="form-label fw-semibold">Hạn trả *</label>
                        <input type="date" name="return_date" class="form-control"
                               value="<?= htmlspecialchars((string)$form->get('return_date')->getValue()) ?>" required>
                        <?php $msgs = $form->get('return_date')->getMessages(); if ($msgs): ?>
                            <div class="text-danger small mt-1"><?= htmlspecialchars(implode(', ', $msgs)) ?></div>
                        <?php endif; ?>
                    </div>
                </div>

                <?= $this->formHidden($form->get('csrf')) ?>
                <?php $msgs = $form->get('csrf')->getMessages(); if ($msgs): ?>
                    <div class="text-danger small mb-3"><?= htmlspecialchars(implode(', ', $msgs)) ?></div>
                <?php endif; ?>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4" <?= $bookOptions === [] || $userOptions === [] ? 'disabled' : '' ?>>
                        <i class="bi bi-check-circle me-1"></i>Xác nhận mượn
                    </button>
                    <a href="<?= $this->url('library/transaction') ?>" class="btn btn-light">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>
</div>
